# Copy to .env.local for local development (never commit secrets)
DATABASE_URL=postgresql://salanor:salanor@127.0.0.1:5432/aegis
# Prisma web CMS only — separate DB; NEVER run `pnpm db:push` against `aegis` (destroys Aegis tables)
# WEB_DATABASE_URL=postgresql://salanor:salanor@127.0.0.1:5432/salanor_web
REDIS_URL=redis://localhost:6379
AEGIS_API_PORT=8080
PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3001
NEXT_PUBLIC_DOCS_BASE_URL=http://localhost:3002
# Salanor employee workspace (separate from customer Aegis Console)
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3003
PLATFORM_ORIGIN=http://localhost:3003
# Contact form → `contact_messages` in the aegis DB (run: pnpm db:migrate)
# Transactional email via Resend (invites, password reset, contact notify) — set RESEND_API_KEY
# RESEND_API_KEY=re_xxxxxxxx
# INVITE_EMAIL_FROM=Salanor <invites@salanor.com>
# EMAIL_FROM=Salanor <noreply@salanor.com>
# CONTACT_NOTIFY_EMAIL=partners@salanor.com
# Optional: Auth.js magic link on apps/web only (SMTP URL). Not required if you use Resend everywhere.
# EMAIL_SERVER=smtp://resend:API_KEY@smtp.resend.com:587
# Marketing contact channels, social links, address (default: apps/web-marketing/data/site-contact.json)
# SITE_CONTACT_PATH=./data/site-contact.json
AEGIS_INGEST_DEV_KEY=aegis_dev_local_change_me
DEV_SIGNING_PRIVATE_KEY_B64=mqUA8ONIg7SN0gL8luCakqehaIzp8Lys6ZHMjAoBx/M=
AEGIS_API_URL=http://127.0.0.1:8080
# web-console browser → API (not used by apps/web-docs — docs use https://api.salanor.com by default)
NEXT_PUBLIC_AEGIS_API_URL=http://127.0.0.1:8080
CONSOLE_ORIGIN=http://localhost:3000
MARKETING_ORIGIN=http://localhost:3001
# Production: SESSION_COOKIE_DOMAIN=.salanor.com (login shared across salanor.com + app.salanor.com)
# SESSION_COOKIE_DOMAIN=.salanor.com
# Console login: per-account scrypt hash in DB. Legacy env passwords still work until first login migrates the hash.
DEV_CONSOLE_PASSWORD_ORG_A=dev-admin-change-me
DEV_CONSOLE_PASSWORD_ORG_B=dev-b-admin-change-me
# Platform Ops: provision orgs, plans, leads — http://localhost:3003 (staff login + platform_staff flag)
# Automation/scripts: POST /v1/id/platform/* with header X-Platform-Secret
PLATFORM_BOOTSTRAP_SECRET=local-platform-secret-change-me
# Organization invites: link always printed in Salanor ID terminal (pnpm dev:id).
# Optional delivery via Resend — https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# INVITE_EMAIL_FROM=Salanor <invites@notifications.salanor.com>
# Pending approval notifications (Slack and/or email deep link to console)
# APPROVAL_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# APPROVAL_NOTIFY_EMAIL=ops@yourcompany.com,security@yourcompany.com
COMPLIANCE_EXPORT_DIR=./.data/compliance-exports
# Server-side ZIP staging (API). Users download via console → browser save dialog.
# Optional: daily cron for monthly compliance export schedules → pnpm compliance:schedule
SALANOR_ID_URL=http://127.0.0.1:8091
SALANOR_ID_PORT=8091
# Start ID: pnpm dev:id  (package name is "id", not salanor-id)
INSURANCE_API_URL=http://127.0.0.1:8092
INSURANCE_API_PORT=8092
# Self-serve signup (customer creates org + account on :3000/signup)
SELF_SERVE_SIGNUP_ENABLED=1
NEXT_PUBLIC_SELF_SERVE_SIGNUP_ENABLED=1
# BILLING_CHECKOUT_ENABLED=1
# NEXT_PUBLIC_BILLING_CHECKOUT_ENABLED=1
# BILLING_API_URL=http://127.0.0.1:8093
# BILLING_API_PORT=8093
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen --forward-to localhost:8093/v1/billing/webhooks/stripe
# Usage rollup reconcile: pnpm billing:usage-backfill
# Salanor ID — OAuth (console login at :3000). Callback: {CONSOLE_ORIGIN}/api/id/auth/oauth/{provider}/callback
# AUTH_SECRET=                          # openssl rand -hex 32 — required in production (OAuth state / PKCE)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# Enterprise SSO (WorkOS): https://workos.com — callback {CONSOLE_ORIGIN}/api/id/auth/sso/callback
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# SSO_WORKOS_ORG_MAP={"jmt-s":"org_workos_id_here"}   # pilot map slug → WorkOS org id (or use organization_sso table)
# organization_sso.jit_provision=true — first SSO login creates account + membership (run migration 022)
# Rate limits (per API instance; use edge/WAF in production for global limits)
# INGEST_RATE_LIMIT_PER_MIN=300
# LOGIN_RATE_LIMIT=20
# LOGIN_RATE_WINDOW_MS=900000   # milliseconds (900000 = 15 minutes), per Salanor ID instance
# Production: also rate-limit /auth/oauth at your CDN/WAF (Cloudflare, etc.)
# Optional error monitoring (aegis-api + salanor-id)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_RELEASE=salanor@local
