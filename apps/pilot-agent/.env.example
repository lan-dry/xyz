# Pilot agent — copy to .env (never commit)

AEGIS_API_URL=http://127.0.0.1:8080
AEGIS_INGEST_API_KEY=          # Console → API keys → create → copy secret

PILOT_ORGANIZATION_ID=         # From signup or Platform Ops provision
PILOT_AGENT_ID=                # Same
PILOT_KEY_ID=                  # Same
PILOT_SIGNING_PRIVATE_KEY_B64= # Shown once at signup/provision

