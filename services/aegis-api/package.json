{
  "name": "aegis-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate-cli.ts up",
    "db:migrate:down": "tsx src/db/migrate-cli.ts down",
    "db:seed": "tsx src/db/seed-cli.ts",
    "compliance:worker": "tsx src/compliance/worker-cli.ts",
    "compliance:schedule": "tsx src/compliance/schedule-cli.ts",
    "publish-transparency": "tsx src/transparency/publish-cli.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@open-policy-agent/opa-wasm": "^1.10.0",
    "@salanor/aegis": "workspace:*",
    "@salanor/observability": "workspace:*",
    "@salanor/platform-auth": "workspace:*",
    "@salanor/witness-merkle": "workspace:*",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.7",
    "hono": "^4.7.11",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@salanor/config": "workspace:*",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.4",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.4"
  },
  "nx": {
    "tags": ["type:service", "scope:aegis"]
  }
}
