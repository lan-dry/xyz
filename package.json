{
  "name": "salanor",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node tools/scripts/dev-all.mjs",
    "dev:web": "nx run-many -t dev --projects=@salanor/web-console,@salanor/web-docs,@salanor/web-marketing,@salanor/web-platform --parallel=4",
    "dev:api": "nx run-many -t dev --projects=aegis-api,id,insurance-api --parallel=3",
    "dev:platform": "nx run @salanor/web-platform:dev",
    "dev:core": "nx run-many -t dev --projects=@salanor/web-console,aegis-api,id --parallel=3",
    "lint": "nx run-many -t lint --all",
    "typecheck": "nx run-many -t typecheck --all",
    "test": "nx run-many -t test --all",
    "db:migrate": "pnpm --filter aegis-api db:migrate",
    "db:migrate:down": "pnpm --filter aegis-api db:migrate:down",
    "db:seed": "pnpm --filter aegis-api db:seed",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:web": "prisma db push",
    "db:migrate:web": "prisma migrate dev",
    "demo:ingest": "pnpm --filter @salanor/demo-tools ingest-one-event",
    "demo:verify-chain": "pnpm --filter @salanor/demo-tools verify-chain",
    "demo:proxy": "pnpm --filter @salanor/demo-tools proxy-fetch",
    "demo:full-system": "pnpm --filter @salanor/demo-tools full-system",
    "pilot:e2e": "node tools/scripts/e2e-onboarding.mjs",
    "pilot:plan-limit": "pnpm --filter @salanor/demo-tools verify-plan-limit",
    "pilot:phase-a": "node tools/scripts/phase-a-api-smoke.mjs",
    "pilot:agent": "pnpm --filter @salanor/pilot-agent pilot",
    "pilot:agent:rebuild": "pnpm --filter @salanor/aegis build && pnpm --filter @salanor/pilot-agent pilot",
    "pilot:ensure-policy": "pnpm --filter @salanor/demo-tools ensure-pilot-policy",
    "sdk:conformance": "pnpm --filter @salanor/aegis build && node tools/conformance/sdk-signing.mjs && cd sdks/go && go test ./... && cd ../python && python -m pip install -q -e \".[dev]\" && python -m pytest -q",
    "sdk:conformance:ts-py": "pnpm --filter @salanor/aegis build && node tools/conformance/sdk-signing.mjs && cd sdks/python && python -m pip install -q -e \".[dev]\" && python -m pytest -q",
    "pilot:reset": "node tools/scripts/pilot-reset.mjs",
    "billing:usage-backfill": "pnpm --filter billing usage:backfill",
    "dev:billing": "pnpm --filter billing dev",
    "witness:batch": "pnpm --filter aegis-signer batch",
    "transparency:publish": "pnpm --filter aegis-api publish-transparency",
    "demo:verify-inclusion": "pnpm --filter @salanor/demo-tools verify-inclusion",
    "verifier:public": "node tools/verifier/verify.mts",
    "compliance:worker": "pnpm --filter aegis-api compliance:worker",
    "build": "nx run-many -t build --all"
  },
  "devDependencies": {
    "@nx/eslint": "21.2.0",
    "@nx/eslint-plugin": "21.2.0",
    "@nx/js": "21.2.0",
    "@nx/next": "21.2.0",
    "@nx/node": "21.2.0",
    "@nx/workspace": "21.2.0",
    "@prisma/client": "6.3.1",
    "@salanor/config": "workspace:*",
    "eslint": "^9.28.0",
    "nx": "21.2.0",
    "prisma": "6.3.1",
    "typescript": "^5.8.3"
  }
}
