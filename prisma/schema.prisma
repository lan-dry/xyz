// Salanor web DB — see docs/DATA_MODEL_WEB.md

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Neon production: set DIRECT_DATABASE_URL to the unpooled URL for `prisma migrate`.
  // Local dev: DATABASE_URL alone is enough for `db push`.
}

model Author {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  role      String
  bio       String
  photoUrl  String?  @map("photo_url")
  links     Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  researchPosts ResearchPost[]

  @@map("authors")
}

model ResearchPost {
  id             String    @id @default(uuid()) @db.Uuid
  slug           String    @unique
  title          String
  dek            String
  body           String
  authorId       String?   @map("author_id") @db.Uuid
  author         Author?   @relation(fields: [authorId], references: [id])
  track          String
  publishedAt    DateTime? @map("published_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  readingMinutes Int       @map("reading_minutes")
  heroImageUrl   String?   @map("hero_image_url")
  ogImageUrl     String?   @map("og_image_url")
  status         String

  @@index([status, publishedAt(sort: Desc)])
  @@map("research_posts")
}

model OpenRole {
  id                String    @id @default(uuid()) @db.Uuid
  slug              String    @unique
  title             String
  team              String
  location          String
  seniority         String
  employmentType    String    @map("employment_type")
  summary           String
  requirements      String
  compensationRange String?   @map("compensation_range")
  postedAt          DateTime  @map("posted_at") @db.Timestamptz(6)
  closesAt          DateTime? @map("closes_at") @db.Timestamptz(6)
  status            String

  @@index([status, postedAt(sort: Desc)])
  @@map("open_roles")
}

model ContactMessage {
  id           String   @id @default(uuid()) @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  name         String
  email        String
  organization String?
  role         String?
  reason       String
  message      String
  sourcePath   String   @map("source_path")
  ipHash       String   @map("ip_hash")
  status       String   @default("new")
  adminNotes   String?  @map("admin_notes")
  updatedBy    String?  @map("updated_by")

  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("contact_messages")
}

model NewsletterSubscriber {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  confirmedAt    DateTime? @map("confirmed_at") @db.Timestamptz(6)
  source         String
  unsubscribedAt DateTime? @map("unsubscribed_at") @db.Timestamptz(6)

  @@index([email])
  @@map("newsletter_subscribers")
}

// Auth.js (NextAuth) — see packages/auth
model User {
  id                   String    @id @default(uuid()) @db.Uuid
  name                 String?
  email                String?   @unique
  emailVerified        DateTime? @map("email_verified") @db.Timestamptz(6)
  image                String?
  totpSecretEnc        String?   @map("totp_secret_enc")
  totpEnabledAt        DateTime? @map("totp_enabled_at") @db.Timestamptz(6)
  platformSuspendedAt  DateTime? @map("platform_suspended_at") @db.Timestamptz(6)
  accounts             Account[]
  sessions             Session[]
  identityLink         IdentityLink?

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SalInternalUser {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  role      String   @default("support")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("sal_internal_users")
}

// Aegis P4 — console tenancy (see docs/DATA_MODEL_AEGIS_CONSOLE.md)
enum OrganizationRole {
  owner
  admin
  developer
  compliance
  viewer

  @@map("organization_role")
}

enum OrganizationBillingStatus {
  none
  trialing
  active
  past_due
  canceled

  @@map("organization_billing_status")
}

model IdentityLink {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryEmail String   @map("primary_email")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships        OrganizationMembership[]
  apiKeysCreated     ApiKey[]                 @relation("ApiKeyCreatedBy")
  membershipsInvited OrganizationMembership[] @relation("MembershipInvitedBy")
  invitesSent        OrganizationInvite[]     @relation("OrganizationInviteInvitedBy")
  auditLogsAsActor   ConsoleAuditLog[]

  @@map("identity_links")
}

model Organization {
  id                   String                    @id @default(uuid()) @db.Uuid
  name                 String
  slug                 String                    @unique
  externalOrgId        String?                   @unique @map("external_org_id")
  plan                 String                    @default("starter")
  stripeCustomerId     String?                   @map("stripe_customer_id")
  stripeSubscriptionId String?                   @map("stripe_subscription_id")
  billingStatus        OrganizationBillingStatus @default(none) @map("billing_status")
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  memberships  OrganizationMembership[]
  apiKeys      ApiKey[]
  invites      OrganizationInvite[]
  ingestEvents AegisIngestEvent[]
  auditLogs    ConsoleAuditLog[]
  policies     AegisPolicy[]
  policyLogs   PolicyEvaluationLog[]

  @@map("organizations")
}

model AegisPolicy {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  version        Int          @default(1)
  rules          Json         @db.JsonB
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  evaluationLogs PolicyEvaluationLog[]

  @@index([organizationId, enabled, createdAt(sort: Desc)])
  @@map("aegis_policies")
}

model PolicyEvaluationLog {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policyId       String?       @map("policy_id") @db.Uuid
  policy         AegisPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  traceId        String        @map("trace_id")
  eventId        String        @map("event_id")
  decision       String
  violations     Json?         @db.JsonB
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([policyId, createdAt(sort: Desc)])
  @@index([traceId, createdAt(sort: Desc)])
  @@map("policy_evaluation_log")
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  identityLinkId String           @map("identity_link_id") @db.Uuid
  identityLink   IdentityLink     @relation(fields: [identityLinkId], references: [id], onDelete: Cascade)
  role           OrganizationRole
  invitedById    String?          @map("invited_by") @db.Uuid
  invitedBy      IdentityLink?    @relation("MembershipInvitedBy", fields: [invitedById], references: [id])
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([organizationId, identityLinkId])
  @@index([identityLinkId])
  @@map("organization_memberships")
}

model OrganizationInvite {
  id             String           @id @default(uuid()) @db.Uuid
  email          String
  organizationId String           @map("organization_id") @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrganizationRole
  tokenHash      String           @map("token_hash")
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(6)
  revokedAt      DateTime?        @map("revoked_at") @db.Timestamptz(6)
  invitedById    String           @map("invited_by") @db.Uuid
  invitedBy      IdentityLink     @relation("OrganizationInviteInvitedBy", fields: [invitedById], references: [id])
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([email, expiresAt])
  @@unique([tokenHash])
  @@map("organization_invites")
}

model ApiKey {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  prefix         String
  secretHash     String       @map("secret_hash")
  scopes         Json?        @db.JsonB
  createdById    String       @map("created_by") @db.Uuid
  createdBy      IdentityLink @relation("ApiKeyCreatedBy", fields: [createdById], references: [id])
  revokedAt      DateTime?    @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt     DateTime?    @map("last_used_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([organizationId])
  @@map("api_keys")
}

model ConsoleAuditLog {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String?       @map("organization_id") @db.Uuid
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorIdentityId String        @map("actor_identity_id") @db.Uuid
  actor           IdentityLink  @relation(fields: [actorIdentityId], references: [id])
  action          String
  targetType      String?       @map("target_type")
  targetId        String?       @map("target_id")
  metadata        Json?         @db.JsonB
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("console_audit_log")
}

// Aegis P2/P3 — ledger index (P3: sole writer = aegis-ledger-writer consumer)
model AegisIngestEvent {
  id              String              @id @default(uuid()) @db.Uuid
  organizationId  String?             @map("organization_id") @db.Uuid
  organization    Organization?       @relation(fields: [organizationId], references: [id])
  traceId         String              @map("trace_id") @db.Uuid
  payload         Json                @db.JsonB
  payloadBlobKey  String?             @map("payload_blob_key")
  receivedAt      DateTime            @default(now()) @map("received_at") @db.Timestamptz(6)
  idempotencyKey  String?             @unique @map("idempotency_key")
  batchId         String?             @map("batch_id") @db.Uuid
  batch           AegisLedgerBatch?  @relation(fields: [batchId], references: [id])

  @@index([organizationId, receivedAt(sort: Desc)])
  @@index([traceId, receivedAt(sort: Desc)])
  @@index([batchId])
  @@map("aegis_ingest_events")
}

// Aegis P3 — Merkle batch + anchor stub (OTS interface later)
model AegisLedgerBatch {
  id             String              @id @default(uuid()) @db.Uuid
  merkleRoot     String              @map("merkle_root")
  eventCount     Int                 @map("event_count")
  anchorStatus   String              @map("anchor_status")
  anchorRef      String?             @map("anchor_ref")
  localChainRoot String?             @map("local_chain_root")
  otsBlobKey     String?             @map("ots_blob_key")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  events         AegisIngestEvent[]

  @@index([createdAt(sort: Desc)])
  @@map("aegis_ledger_batches")
}
